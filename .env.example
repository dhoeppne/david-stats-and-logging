# Copy to .env and fill in.

# Public domain used to build Grafana/Prometheus external URLs.
# e.g. dbh.fyi → resulting URLs https://grafana.dbh.fyi, https://prometheus.dbh.fyi
PUBLIC_DOMAIN=dbh.fyi

# Grafana admin password (initial). Change after first login if desired.
GRAFANA_ADMIN_PASSWORD=change-me-now

# Alert webhook (Discord/Slack/webhook.site). Used by Grafana contact point.
# Discord example: https://discord.com/api/webhooks/123/abc
# Slack example:   https://hooks.slack.com/services/T00/B00/XXX
ALERT_WEBHOOK_URL=https://webhook.site/REPLACE-ME
