{
  "id": null,
  "uid": "log-explorer",
  "title": "Log Explorer",
  "tags": ["loki", "logs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "loki",
        "current": { "selected": true, "text": "Loki", "value": "loki" }
      },
      {
        "name": "host",
        "type": "query",
        "datasource": { "type": "loki", "uid": "${datasource}" },
        "query": "label_values(host)",
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "container",
        "type": "query",
        "datasource": { "type": "loki", "uid": "${datasource}" },
        "query": "label_values({host=~\"$host\"}, container)",
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "level",
        "type": "custom",
        "query": "All,debug,info,warn,error",
        "current": { "selected": true, "text": "All", "value": "All" }
      },
      {
        "name": "search",
        "type": "textbox",
        "current": { "text": "", "value": "" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Log volume",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (host) (rate({host=~\"$host\", container=~\"$container\"} |~ \"(?i)$search\" [1m]))",
          "legendFormat": "{{host}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "logs/s" } }
    },
    {
      "id": 2,
      "type": "logs",
      "title": "Logs",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 18 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{host=~\"$host\", container=~\"$container\"} |~ \"(?i)$search\"",
          "maxLines": 1000
        }
      ]
    }
  ]
}
