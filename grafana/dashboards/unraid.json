{
  "id": null,
  "uid": "unraid",
  "title": "Unraid",
  "tags": ["unraid", "home"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": true, "text": "Prometheus", "value": "prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Array status",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "unraid_array_status", "refId": "A", "legendFormat": "status" }
      ],
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "value" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "Started", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "Stopped", "color": "red" } } }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Docker containers running",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "count(unraid_docker_container_running == 1)", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Cache used %",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "unraid_cache_used_bytes / unraid_cache_size_bytes * 100", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "min": 0 } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Array used %",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "unraid_array_used_bytes / unraid_array_size_bytes * 100", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "min": 0 } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Disk temperatures (°C)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "unraid_disk_temperature_celsius", "refId": "A", "legendFormat": "{{disk}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "red", "value": 45 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Container states",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "unraid_docker_container_running", "refId": "A", "format": "table", "instant": true }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true } } }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "running", "color": "green" }, "0": { "text": "stopped", "color": "red" } } }
          ]
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Cache hit ratio",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "rate(unraid_cache_hits_total[5m]) / (rate(unraid_cache_hits_total[5m]) + rate(unraid_cache_misses_total[5m]))", "refId": "A", "legendFormat": "hit ratio" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "NAS network throughput",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{host=\"nas\",device!~\"lo|veth.*|br-.*|docker.*\"}[5m])*8", "refId": "A", "legendFormat": "rx {{device}}" },
        { "expr": "rate(node_network_transmit_bytes_total{host=\"nas\",device!~\"lo|veth.*|br-.*|docker.*\"}[5m])*8", "refId": "B", "legendFormat": "tx {{device}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps" } }
    }
  ]
}
